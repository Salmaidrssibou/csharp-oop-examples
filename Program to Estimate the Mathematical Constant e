Console.Write("Enter a number of terms for e estimation: ");
int t = int.Parse(Console.ReadLine());

double e = 0;
double factorial = 1.0;
int i = 1;

while (i <= t)
{
    factorial *= i;
    e += 1.0 / factorial;
    i++;
}

Console.WriteLine($"Estimated e = {e}");
Console.Write($"Math.E = {Math.E}");
